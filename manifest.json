{
    "manifest_version": 3,
    "name": "Open in Freedium",
    "version": "1.0",
    "description": "A simple extension to open Medium articles in Freedium.",
    "permissions": [
        "contextMenus",
        "tabs"
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "icons": {
        "48": "assets/icon48_rm.jpeg"
    }
}